  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a92af01d0ab9345b48211f8a4c9b3b78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NystagmusSim
  handicapTitle: Nystagmus
  explanation: "Le <b>nystagmus</b> provoque des mouvements involontaires et r\xE9p\xE9titifs
    des yeux.\n\nSur Meta Quest 3S, cette sc\xE8ne utilise le passthrough et applique
    une oscillation contr\xF4l\xE9e au rep\xE8re de tracking : l'environnement r\xE9el
    semble instable, comme lors d'une oscillopsie.\n\nLe stick droit haut/bas ajuste
    l'intensit\xE9 pendant la simulation."
  correctionText: "La prise en charge d\xE9pend de la cause :\n\n<b>-</b> Correction
    optique et parfois prismes pour am\xE9liorer la position de regard\n<b>-</b>
    R\xE9\xE9ducation orthoptique quand elle est pertinente\n<b>-</b> Traitement
    neurologique, toxine botulique ou chirurgie des muscles oculomoteurs dans certains
    cas\n\nDans cette sc\xE8ne, la correction r\xE9duit l'amplitude des secousses
    pour visualiser une stabilisation."
  anatomyPart: Muscles
  accent: {r: 0.13, g: 0.7, b: 0.76, a: 1}
  challengeKey: nystagmus
  challengeInstructions: "Observez l'oeil et ressentez l'oscillopsie simul\xE9e dans
    le casque."
  menuSceneName: SampleScene
  headAnchor: {fileID: 1617850138}
  distance: 1.5
  verticalOffset: -0.1
  followSmoothing: 6
  eyeModelPrefab: {fileID: 0}
  hideButton: 4
  toggleHandicapButton: 8
  eyeDiseasedScaleFactor: {x: 1.12, y: 0.84, z: 1.12}
  intensityAxis: 2
  intensity: 0.38
  intensitySpeed: 0.55
  stickDeadZone: 0.15
  type: 0
  beatDirection: 0
  frequencyHz: 4
  maxAmplitudeYawDeg: 8
  slowPhaseFraction: 0.8
  foveationPauseAmount: 0.55
  verticalContributionDeg: 0.6
  torsionalContributionDeg: 0.4
  naturalTremorDeg: 0.3
  cameraTremorOnly: 1
  useMotionSmear: 0
  smearDistance: 0.34
  smearScale: {x: 1.85, y: 1.12}
  smearMaxAlpha: 0.24
  visibleFieldJitterMeters: 0.035
