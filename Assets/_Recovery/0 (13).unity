  m_Script: {fileID: 11500000, guid: a92af01d0ab9345b48211f8a4c9b3b78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NystagmusSim
  handicapTitle: Nystagmus
  explanation: "Le <b>nystagmus</b> provoque des mouvements involontaires et r\xE9p\xE9titifs
    des yeux.\n\nIci, la sc\xE8ne ne met pas un filtre abstrait devant le casque
    : elle montre directement <b>l'\u0153il qui oscille</b> et les <b>muscles oculomoteurs</b>
    impact\xE9s.\n\nL'animation reste supportable sur Quest. Le bouton d'intensit\xE9
    sert uniquement \xE0 accentuer la d\xE9monstration."
  correctionText: "La prise en charge d\xE9pend de la cause :\n\n<b>\u2022</b> Correction
    optique et parfois <b>prismes</b> pour am\xE9liorer la position de regard\n<b>\u2022</b>
    R\xE9\xE9ducation orthoptique quand elle est pertinente\n<b>\u2022</b> Traitement
    neurologique, toxine botulique ou chirurgie des muscles oculomoteurs dans certains
    cas\n\n<i>Dans cette sc\xE8ne, la correction r\xE9duit l'amplitude des secousses
    pour visualiser une stabilisation.</i>"
  anatomyPart: Muscles
  accent: {r: 0.13, g: 0.7, b: 0.76, a: 1}
  challengeKey: nystagmus
  challengeInstructions: "Observation anatomique : regardez l'\u0153il et les muscles
    oculomoteurs mis en \xE9vidence."
  menuSceneName: SampleScene
  headAnchor: {fileID: 0}
  distance: 1.5
  verticalOffset: -0.1
  followSmoothing: 6
  eyeModelPrefab: {fileID: 0}
